# Required
GEMINI_API_KEY=your_gemini_api_key_here

# Optional
GEMINI_MODEL=gemini-flash-latest
PORT=5000
FLASK_DEBUG=false
STATE_FILE=stadium_state.json
RATE_LIMIT_PER_MIN=30

# Protects /api/state POST, /api/events POST, /api/state/reset from
# unauthorized modification. Set to any random string in production.
# Leave empty to allow unauthenticated mutations in dev/demo environments.
OPERATOR_SECRET=
